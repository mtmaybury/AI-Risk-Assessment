} 

# ------------------------------------------------------------- 
# 2️⃣ Normalisation helpers (0 1 scale) 
# ------------------------------------------------------------- 

def norm(series, reverse=False): 
"""Linear min max to 0 1. If reverse=True larger raw = lower norm.""" 
mn, mx = series.min(), series.max() 
if mx == mn: 
     return pd.Series(0.5, index=series.index) # avoid divide by 0 
normed = (series - mn) / (mx - mn) 
return 1 - normed if reverse else normed 

# ------------------------------------------------------------- 
# 3️⃣ Assemble raw metrics for each model 
# ------------------------------------------------------------- 
# Mapping from human readable name → API token used by the data sources 
model_key = { 
"GPT 4 Turbo": "gpt-4", 
"Gemini 1.5 Pro": "gemini-1.5-pro", 
"Claude 3 Opus": "claude-3-opus", 
"LLaMA 2 70B": "llama2-70b", 
"Mistral Large": "mistral-large" 
} 

# raw fetches 
hall = fetch_hallucination() 
jail = fetch_jailbreak() 
bias = fetch_bias() 

# Build a DataFrame with one row per model 
rows = [] 
for name, key in model_key.items(): 
rows.append({ 
"Model": name, 
"Halluc_%": 100 * hall.loc[key, "hallucination_rate"], 
"Jailbreak_%": 100 * jail.loc[key, "success_rate"], 
"Bias_DI": bias.loc[key, "stereoset_disparity"], # 1.0 = no dis-parity 
}) 
raw = pd.DataFrame(rows).set_index("Model") 

# ------------------------------------------------------------- 
# 4️⃣ Compute CIA sub scores (0 1) and the final Risk 
# ------------------------------------------------------------- 
# Threat = weighted blend of frequency & severity of incidents 
# (here we simply use #incidents as proxy for frequency) 
threat_raw = pd.Series({ 
"GPT 4 Turbo": fetch_incidents("OpenAI")["inc_last_12mo"], 
"Gemini 1.5 Pro": fetch_incidents("Google")["inc_last_12mo"],
"Claude 3 Opus": fetch_incidents("Anthropic")["inc_last_12mo"],
"LLaMA 2 70B": fetch_incidents("Meta")["inc_last_12mo"], 
"Mistral Large": fetch_incidents("MistralAI")["inc_last_12mo"] 
}) 
threat = norm(threat_raw, reverse=False) # higher count ⇒ higher threat 

# Vulnerability = blend of hallucination + jailbreak + bias 
# (simple average; you can apply custom weights) 
vuln = (norm(raw["Halluc_%"], reverse=False) + 
norm(raw["Jailbreak_%"], reverse=False) + 
norm(raw["Bias_DI"], reverse=True)) / 3 
# bias: higher DI = less bias → reverse 

# Consequence – paper used a flat 0.5 for illustration; you can plug a 
# domain specific weight (e.g., finance = 0.8, education = 0.3) 
consequence = pd.Series(0.5, index=raw.index) 

# Final risk = T × V × C (geometric mean can also be used)
# (Also a feature weighted average can be used as shown in Figure 1)
risk = threat * vuln * consequence 

# ------------------------------------------------------------- 
# 5️⃣ Output table 
# ------------------------------------------------------------- 
summary = pd.concat([threat.rename("Threat"), 
vuln.rename("Vuln"), 
consequence.rename("Conseq"), 
risk.rename("Risk")], axis=1) 

print("=== CIA Risk Summary for the Top 5 Global LLMs ===") 
display(summary.round(3))

 

