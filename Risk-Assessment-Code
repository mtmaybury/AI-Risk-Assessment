def fetch_github_hallucination():
    # GitHub Hallucination Leaderboard JSON endpoint (public)
    url = "https://raw.githubusercontent.com/openai/hallucination-leaderboard/main/leaderboard.json"
    return pd.DataFrame(requests.get(url).json())

def fetch_anthropic_jailbreak():
    # Anthropic Red Team dataset – success rate per model
    url = "https://raw.githubusercontent.com/anthropic/redteam-data/main/jailbreak_summary.json"
    return pd.DataFrame(requests.get(url).json())

def fetch_bias_metrics():
    # Community bias suite (StereoSet + HateCheck) – aggregated per model 
    url = "https://raw.githubusercontent.com/allenai/LLM Bias Benchmarks/main/summary.csv"
    return pd.read_csv(url)

def fetch_ops_incidents():
    # AI Incident Database query for a provider (simple GET)
    def query(provider):
        q = f"https://incidentdatabase.ai/api/v1/incidents?provider={provider}"
        return pd.DataFrame(requests.get(q).json()["results"])
    return {p: query(p) for p in ["Open-AI","Anthropic","Google","Meta","MistralAI"]}
