7.4 Threat Likelihood Calculation (Python snippet)
import requests, pandas as pd, datetime as dt

def fetch_incidents(provider):
    """Return a DataFrame of AIID incidents for a given provider."""
    url = f"https://incidentdatabase.ai/api/v1/incidents?provider={provider}"
    data = requests.get(url).json()["results"]
    df = pd.DataFrame(data)
    df["date"] = pd.to_datetime(df["date"])
    return df

def incident_stats(provider, lookback_days=365):
    df = fetch_incidents(provider)
    now = dt.datetime.utcnow()
    # total incidents ever reported
    total = len(df)
    # incidents in the last lookback period
    recent = df[df["date"] >= now - dt.timedelta(days=lookback_days)]
    recent_cnt = len(recent)
    # mean severity (Low=1, Medium=2, High=3)
    severity_map = {"Low": 1, "Medium": 2, "High": 3}
    recent["sev_num"] = recent["severity"].map(severity_map)
    mean_sev = recent["sev_num"].mean() if recent_cnt else 0
    return {
        "total": total,
        "last_12mo": recent_cnt,
        "annualised_rate": recent_cnt,   # 12 mo window → same number
        "mean_severity": round(mean_sev, 2)
    }

providers = {
    "GPT 4": "OpenAI",
    "Claude 3 Opus": "Anthropic",
    "Gemini 1.5 Pro": "Google",
    "LLaMA 2 70B": "Meta",
    "Mistral Large": "MistralAI"
}

stats = {name: incident_stats(pid) for name, pid in providers.items()}
df = pd.DataFrame.from_dict(stats, orient='index')
print(df)
